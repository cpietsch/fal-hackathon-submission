# copy to .env and fill in — the server auto-loads it on start

# fal.ai key: powers Exact mode (Wan VACE depth), transcription, camera
# language and — without a Kling key — Beautiful mode (Seedance)
FAL_KEY=

# Kling key (a fal key with Kling access): when set, Beautiful mode runs
# Kling instead of Seedance; reference images use its image-to-video variant
KLING_KEY=

# optional model overrides
# KLING_MODEL=fal-ai/kling-video/v2.5-turbo/pro/text-to-video
# KLING_MODEL_I2V=fal-ai/kling-video/v2.5-turbo/pro/image-to-video
